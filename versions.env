# Pinned versions for the CCW Elixir runtime bundle.
# Bump these, rerun scripts/build_bundle.sh, upload the resulting tarball
# to a new GitHub release, and update RELEASE_TAG to match.

ASDF_VERSION=v0.19.0
OTP_VERSION=27.2
ELIXIR_VERSION=1.18.3-otp-27

# Tag of the GitHub release that hosts the prebuilt tarball.
# build_bundle.sh prints the tag to use; setup.sh ignores this (the user
# pastes the tarball URL into the CCW startup block directly).
RELEASE_TAG=otp27.2-elixir1.18.3-v4
